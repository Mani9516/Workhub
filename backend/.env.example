SECRET_KEY=replace-with-long-random-string
DATABASE_URL=sqlite:///./data/workhub.db

# --- Email sign-in (SMTP) — set for real OTP delivery ---
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@example.com
# SMTP_USE_TLS=true
# LOGIN_OTP_EXPIRE_MINUTES=10

# Development only: print OTP to API logs instead of sending email (never enable in production)
# LOGIN_OTP_LOG_TO_CONSOLE=false

# When true, API startup deletes all certification_entries (demo reset). Default false for local .env.
# CLEAR_CERTIFICATIONS_ON_START=false
